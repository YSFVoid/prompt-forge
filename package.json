{
    "name": "prompt-forge",
    "version": "1.0.0",
    "private": true,
    "description": "Enterprise-grade Idea-to-Prompt Generator Platform",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev:api",
        "dev:api": "npm run dev --workspace=@prompt-forge/api",
        "dev:web": "npm run dev --workspace=@prompt-forge/web",
        "build": "npm run build --workspaces --if-present",
        "build:api": "npm run build --workspace=@prompt-forge/api",
        "build:web": "npm run build --workspace=@prompt-forge/web",
        "lint": "npm run lint --workspaces --if-present",
        "clean": "npm run clean --workspaces --if-present && rimraf node_modules"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "author": "Prompt Forge Team",
    "license": "MIT"
}