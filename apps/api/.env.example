# API Configuration
NODE_ENV=development
PORT=3001

# Public Mode - Set to true to skip user authentication
PUBLIC_MODE=true

# MongoDB (optional in public mode)
# MONGODB_URI=mongodb://localhost:27017/prompt-forge

# Groq API (required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Admin Key
ADMIN_KEY=your_secure_admin_key_here

# CORS
CORS_ORIGIN=http://localhost:3000
